# Environment
NODE_ENV=development

# Server
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL="mysql://root:password@localhost:3306/crm_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# AI Service - 阿里云百炼
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-plus

# Serper API - Google搜索服务（用于企业信息搜索）
# 免费层: 2500次/月，获取API Key: https://serper.dev/
SERPER_API_KEY=your-serper-api-key-here

# 企查查API - 企业工商信息查询
# 官方文档: https://openapi.qcc.com/
# 获取密钥: 注册后前往「账号安全」页面获取AppKey和SecretKey
QCC_APP_KEY=your-qcc-app-key-here
QCC_SECRET_KEY=your-qcc-secret-key-here

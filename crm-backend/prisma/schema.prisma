// Prisma Schema for CRM System
// Database: MySQL 8.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== Enums ====================

enum Sentiment {
  positive
  neutral
  negative
}

enum TaskType {
  call
  meeting
  email
  visit
  follow_up
  other
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum ProposalStatus {
  draft                 // 草稿
  requirement_analysis  // 需求分析中
  designing             // 方案设计中
  pending_review        // 待内部评审
  review_passed         // 评审通过
  review_rejected       // 评审驳回
  customer_proposal     // 客户提案中
  negotiation           // 商务谈判中
  sent                  // 已发送
  accepted              // 已接受
  rejected              // 已拒绝
  expired               // 已过期
}

enum TeamRole {
  sales
  manager
  admin
  support
  presales
}

enum ServiceStatus {
  pending
  in_progress
  completed
  on_hold
  cancelled
}

enum MilestoneStatus {
  pending
  in_progress
  completed
}

enum ResourceStatus {
  available
  busy
  offline
}

enum RequestStatus {
  pending
  assigned
  in_progress
  completed
  cancelled
}

enum RequestPriority {
  high
  medium
  low
}

enum OpportunityStatus {
  new_lead
  contacted
  qualified
  proposal
  negotiation
  won
  lost
}

enum PaymentStatus {
  pending
  partial
  paid
  overdue
}

enum ContactRole {
  decision_maker    // 决策人 - 最终拍板、付钱、签合同的人
  key_influencer    // 关键人/影响者 - 能影响决策但不最终拍板
  coach             // 教练/内线 - 站在你这边，给你透信息、帮你指路
  end_user          // 用户 - 未来真正用你产品的人
  gatekeeper        // 把关人 - 筛选方案、控制流程（采购、行政、财务）
  blocker           // 反对者 - 阻碍项目、不支持你的人
}

enum ActivityStatus {
  draft
  pending_approval
  approved
  ongoing
  completed
  cancelled
}

enum ApprovalStatus {
  none
  pending
  approved
  rejected
}

// ==================== User & Authentication ====================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("sales") // admin, manager, sales
  avatar        String?
  department    String?
  phone         String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  ownedCustomers     Customer[]     @relation("CustomerOwner")
  createdCustomers   Customer[]     @relation("CustomerCreatedBy")
  ownedOpportunities Opportunity[]  @relation("OpportunityOwner")
  createdOpportunities Opportunity[] @relation("OpportunityCreatedBy")
  ownedProposals     Proposal[]     @relation("ProposalOwner")
  createdProposals   Proposal[]     @relation("ProposalCreatedBy")
  assignedTasks      ScheduleTask[] @relation("TaskAssignee")
  createdTasks       ScheduleTask[] @relation("TaskCreator")
  teamActivities     TeamActivity[]
  createdServices    ServiceProject[] @relation("ServiceCreator")
  presalesRequests   PreSalesRequest[] @relation("UserPreSalesRequests")
  teamMember         TeamMember?
  createdRecordings  AudioRecording[] @relation("RecordingCreator")
  createdPresales    PreSalesRequest[] @relation("PresalesCreator")
  createdContacts    Contact[]      @relation("ContactCreator")
  createdBusinessCards BusinessCard[] @relation("BusinessCardCreator")
  createdColdVisitRecords ColdVisitRecord[] @relation("ColdVisitCreator")
  dailyReports       DailyReport[]
  salesPerformances  SalesPerformance[]
  coachingSuggestions CoachingSuggestion[]
  createdActivities   PresalesActivity[] @relation("ActivityCreator")
  approvedActivities  PresalesActivity[] @relation("ActivityApprover")

  // Knowledge Base Relations
  knowledgeDocuments  KnowledgeDocument[] @relation("KnowledgeDocCreator")
  contractTemplates   ContractTemplate[]  @relation("ContractTemplateCreator")
  customDataTables    CustomDataTable[]   @relation("CustomTableCreator")

  @@index([email])
  @@index([role])
  @@map("users")
}

// ==================== Customer Management ====================

model Customer {
  id              String   @id @default(uuid())
  name            String
  company         String?
  shortName       String?
  email           String?
  stage           String   @default("new") // new, contacted, qualified, proposal, negotiation, won
  estimatedValue  Decimal  @default(0) @db.Decimal(15, 2)
  nextFollowUp    DateTime?
  source          String?  // direct, referral, website, conference, partner
  priority        String   @default("medium") // high, medium, low
  contactPerson   String?
  phone           String?
  address         String?
  city            String?
  province        String?
  district        String?
  industry        String?
  notes           String?  @db.Text
  lastContactDate DateTime?
  lat             Float?
  lng             Float?
  ownerId         String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // AI分析字段
  lastAnalysisAt  DateTime?  // 最后AI分析时间
  riskScore       Int?       // 流失风险评分 0-100
  engagementScore Int?       // 互动活跃度评分 0-100

  // 客户分类字段
  customerType    String   @default("non_user") // user, non_user, valid_non_user, invalid_non_user

  // 企业信息字段
  companyFullName  String?  // 企业全称
  creditCode       String?  // 统一社会信用代码
  registeredCapital Decimal? @db.Decimal(15, 2) // 注册资本（万元）
  establishDate    DateTime? // 成立日期
  businessScope    String?  @db.Text // 经营范围
  legalPerson      String?  // 法人代表
  companyStatus    String?  // 企业状态（存续、注销等）

  // Relations
  owner           User?              @relation("CustomerOwner", fields: [ownerId], references: [id])
  createdBy       User?              @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  opportunities   Opportunity[]
  payments        Payment[]
  recordings      AudioRecording[]
  scheduleTasks   ScheduleTask[]
  proposals       Proposal[]
  serviceProjects ServiceProject[]
  presalesRequests PreSalesRequest[]
  teamActivities  TeamActivity[]
  contacts        Contact[]
  businessCards   BusinessCard[]
  coldVisitRecords ColdVisitRecord[]
  followUpSuggestions FollowUpSuggestion[]
  churnAlerts     ChurnAlert[]
  customerInsight CustomerInsight?
  presalesActivities PresalesActivity[]
  activitySignIns    ActivitySignIn[]
  activityQuestions  ActivityQuestion[]

  @@index([stage])
  @@index([priority])
  @@index([city])
  @@index([ownerId])
  @@index([createdById])
  @@map("customers")
}

// ==================== Sales Funnel ====================

model Opportunity {
  id                String   @id @default(uuid())
  customerId        String
  title             String
  stage             String   @default("new_lead")
  status            String   @default("active") // active, won, lost
  value             Decimal  @default(0) @db.Decimal(15, 2)
  probability       Int      @default(0)
  ownerId           String?
  priority          String   @default("medium")
  expectedCloseDate DateTime?
  lastActivity      DateTime?
  description       String?  @db.Text
  nextStep          String?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner      User?    @relation("OpportunityOwner", fields: [ownerId], references: [id])
  createdBy  User?    @relation("OpportunityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  score      OpportunityScore?

  @@index([customerId])
  @@index([stage])
  @@index([ownerId])
  @@index([status])
  @@map("opportunities")
}

// ==================== Payments ====================

model Payment {
  id           String   @id @default(uuid())
  invoiceId    String   @unique
  customerId   String
  totalAmount  Decimal  @db.Decimal(15, 2)
  paidAmount   Decimal  @default(0) @db.Decimal(15, 2)
  balance      Decimal  @default(0) @db.Decimal(15, 2)
  status       String   @default("pending") // paid, partial, pending, overdue
  planType     String?
  dueDate      DateTime
  paidDate     DateTime?
  lastReminder DateTime?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

// ==================== AI Audio Recording ====================

model AudioRecording {
  id             String    @id @default(uuid())
  customerId     String
  title          String?
  contactPerson  String?
  duration       Int       @default(0) // seconds
  fileSize       Int?
  recordedAt     DateTime  @default(now())
  sentiment      Sentiment?
  summary        String?   @db.Text
  keywords       Json?     // string[]
  keyPoints      Json?     // string[]
  actionItems    Json?     // string[]
  status         String    @default("pending") // analyzed, pending, processing
  fileUrl        String?
  transcript     String?   @db.Text
  notes          String?   @db.Text
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy  User?    @relation("RecordingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([sentiment])
  @@index([status])
  @@map("audio_recordings")
}

// ==================== Schedule ====================

model ScheduleTask {
  id             String      @id @default(uuid())
  title          String
  description    String?     @db.Text
  dueDate        DateTime
  type           TaskType    @default(other)
  priority       TaskPriority @default(medium)
  status         TaskStatus  @default(pending)
  customerId     String?
  location       String?
  reminder       Boolean     @default(true)
  reminderMinutes Int?
  notes          String?     @db.Text
  assigneeId     String?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignee   User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy  User?     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([status])
  @@map("schedule_tasks")
}

// ==================== Proposals ====================

model Proposal {
  id          String   @id @default(uuid())
  title       String
  customerId  String
  value       Decimal  @default(0) @db.Decimal(15, 2)
  status      ProposalStatus @default(draft)
  description String?  @db.Text
  products    Json?    // Product[]
  terms       String?  @db.Text
  validUntil  DateTime?
  sentAt      DateTime?
  notes       String?  @db.Text
  ownerId     String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner      User?    @relation("ProposalOwner", fields: [ownerId], references: [id])
  createdBy  User?    @relation("ProposalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  // 新增关联
  requirementAnalysis RequirementAnalysis?
  review              ProposalReview?
  customerProposal    CustomerProposalRecord?
  negotiation         NegotiationRecord?

  @@index([customerId])
  @@index([status])
  @@index([ownerId])
  @@map("proposals")
}

// ==================== Team ====================

model TeamMember {
  id           String   @id @default(uuid())
  userId       String?  @unique
  name         String
  email        String?
  phone        String?
  avatar       String?
  role         TeamRole
  department   String?
  position     String?
  targets      Json?    // { revenue, deals, customers }
  skills       Json?    // string[]
  bio          String?  @db.Text
  revenue      Decimal  @default(0) @db.Decimal(15, 2)
  deals        Int      @default(0)
  customers    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  activities       TeamActivity[]
  assignedRequests PreSalesRequest[]

  @@index([department])
  @@index([isActive])
  @@map("team_members")
}

model TeamActivity {
  id                 String   @id @default(uuid())
  memberId           String?
  userId             String?
  type               String   // deal_closed, customer_added, meeting_scheduled, etc.
  title              String
  description        String?  @db.Text
  relatedCustomerId  String?
  relatedOpportunityId String?
  metadata           Json?
  createdAt          DateTime @default(now())

  // Relations
  member          TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  relatedCustomer Customer?   @relation(fields: [relatedCustomerId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([userId])
  @@index([createdAt])
  @@map("team_activities")
}

// ==================== Service Projects ====================

model ServiceProject {
  id           String   @id @default(uuid())
  customerId   String
  name         String
  description  String?  @db.Text
  type         String?
  status       ServiceStatus @default(pending)
  progress     Int      @default(0)
  startDate    DateTime?
  endDate      DateTime?
  completedAt  DateTime?
  budget       Decimal? @db.Decimal(15, 2)
  milestones   Json?    // Milestone[]
  notes        String?  @db.Text
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy  User?    @relation("ServiceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@index([createdById])
  @@map("service_projects")
}

// ==================== PreSales ====================

model PreSalesResource {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String?
  skills         Json?    // string[]
  experience     Int?
  certifications Json?    // string[]
  status         ResourceStatus @default(available)
  availability   String?
  location       String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedRequests PreSalesRequest[]
  matchRecords     ResourceMatchRecord[]

  @@index([status])
  @@map("presales_resources")
}

model PreSalesRequest {
  id                 String   @id @default(uuid())
  customerId         String
  type               String
  title              String
  description        String?  @db.Text
  priority           RequestPriority @default(medium)
  status             RequestStatus @default(pending)
  requiredSkills     Json?    // string[]
  dueDate            DateTime?
  estimatedDuration  Int?
  assignedResourceId String?
  assignedMemberId   String?
  assignedAt         DateTime?
  completedAt        DateTime?
  notes              String?  @db.Text
  requesterId        String?
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedResource PreSalesResource? @relation(fields: [assignedResourceId], references: [id], onDelete: SetNull)
  assignedMember   TeamMember?       @relation(fields: [assignedMemberId], references: [id], onDelete: SetNull)
  requester        User?             @relation("UserPreSalesRequests", fields: [requesterId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("PresalesCreator", fields: [createdById], references: [id], onDelete: SetNull)
  matchRecords     ResourceMatchRecord[]

  @@index([customerId])
  @@index([status])
  @@index([priority])
  @@index([assignedResourceId])
  @@index([assignedMemberId])
  @@map("presales_requests")
}

// ==================== Contacts ====================

model Contact {
  id          String      @id @default(uuid())
  customerId  String
  name        String
  title       String?     // 职位
  department  String?     // 部门
  email       String?
  phone       String?
  mobile      String?     // 手机
  wechat      String?     // 微信
  role        ContactRole @default(end_user)
  isPrimary   Boolean     @default(false)  // 是否主联系人
  notes       String?     @db.Text
  lastContact DateTime?   // 最后联系时间
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("ContactCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([role])
  @@index([department])
  @@map("contacts")
}

// ==================== Business Cards ====================

model BusinessCard {
  id          String   @id @default(uuid())
  customerId  String?
  imageUrl    String
  ocrResult   Json?    // OCR识别结果
  rawData     Json?    // 原始识别数据
  status      String   @default("pending") // pending, processed, failed
  errorMessage String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("BusinessCardCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@map("business_cards")
}

// ==================== AI Features ====================

// 跟进建议
model FollowUpSuggestion {
  id          String   @id @default(uuid())
  customerId  String
  type        String   // call, visit, email, wechat
  priority    String   // high, medium, low
  reason      String   @db.Text
  suggestedAt DateTime @default(now())
  expiresAt   DateTime?
  script      String?  @db.Text  // AI生成的话术
  status      String   @default("pending") // pending, completed, dismissed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
  @@map("follow_up_suggestions")
}

// 日报/周报
model DailyReport {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  type        String   // daily, weekly
  content     String   @db.Text
  summary     String   @db.Text
  highlights  Json?    // 重点事项[]
  risks       Json?    // 风险提示[]
  nextActions Json?    // 下一步行动[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
  @@map("daily_reports")
}

// 商机评分
model OpportunityScore {
  id              String   @id @default(uuid())
  opportunityId   String   @unique
  overallScore    Int      // 总评分 0-100
  winProbability  Int      // 成交概率 0-100

  // 维度评分
  engagementScore Int      // 互动活跃度
  budgetScore     Int      // 预算匹配度
  authorityScore  Int      // 决策人接触度
  needScore       Int      // 需求明确度
  timingScore     Int      // 时机成熟度

  // 分析依据
  factors         Json?    // 评分因子[]
  riskFactors     Json?    // 风险因素[]
  recommendations Json?    // 改进建议[]

  analyzedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("opportunity_scores")
}

// 客户流失预警
model ChurnAlert {
  id          String   @id @default(uuid())
  customerId  String
  riskLevel   String   // high, medium, low
  riskScore   Int      // 0-100
  reasons     Json?    // 流失原因[]
  signals     Json?    // 预警信号[]
  suggestions Json?    // 挽回建议[]
  status      String   @default("active") // active, handled, ignored
  handledAt   DateTime?
  handledBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([riskLevel])
  @@index([status])
  @@map("churn_alerts")
}

// 客户洞察（AI提取）
model CustomerInsight {
  id               String   @id @default(uuid())
  customerId       String   @unique
  extractedNeeds   Json?    // 提取的需求[]
  extractedBudget  Json?    // 预算信息
  decisionMakers   Json?    // 决策人信息[]
  painPoints       Json?    // 痛点[]
  competitorInfo   Json?    // 竞品信息
  timeline         Json?    // 时间线
  confidence       Int      @default(0) // 置信度
  source           String   @default("ai_analysis")
  analyzedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_insights")
}

// ==================== Cold Visit (AI Assistant) ====================

model ColdVisitRecord {
  id                String   @id @default(uuid())
  companyName       String
  inputType         String   // "text" | "image"
  inputContent      String?  @db.Text
  imageUrl          String?
  intelligenceResult Json?   // AI分析结果
  customerId        String?
  status            String   @default("analyzed") // analyzed, converted
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("ColdVisitCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyName])
  @@index([status])
  @@map("cold_visit_records")
}

// ==================== Sales Performance (AI Coach) ====================

// 销售绩效记录
model SalesPerformance {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime @db.Date
  calls           Int      @default(0)
  meetings        Int      @default(0)
  visits          Int      @default(0)
  proposals       Int      @default(0)
  closedDeals     Int      @default(0)
  revenue         Decimal  @default(0) @db.Decimal(15, 2)
  conversionRate  Float?
  avgDealSize     Decimal? @db.Decimal(15, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("sales_performances")
}

// AI教练建议
model CoachingSuggestion {
  id          String   @id @default(uuid())
  userId      String
  type        String   // performance, skill, opportunity, time_management
  priority    String   // high, medium, low
  title       String
  description String   @db.Text
  actions     Json?    // 建议行动[]
  metrics     Json?    // 相关指标
  status      String   @default("pending") // pending, completed, dismissed
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("coaching_suggestions")
}

// ==================== Resource Matching ====================

// 资源匹配记录
model ResourceMatchRecord {
  id               String   @id @default(uuid())
  requestId        String
  resourceId       String
  matchScore       Float
  matchedSkills    Json?    // 匹配的技能[]
  missingSkills    Json?    // 缺失的技能[]
  aiRecommendation Boolean  @default(false)
  factors          Json?    // 匹配因子详情
  createdAt        DateTime @default(now())

  request  PreSalesRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  resource PreSalesResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([resourceId])
  @@map("resource_match_records")
}

// ==================== Presales Activity Management ====================

// 售前活动
model PresalesActivity {
  id             String          @id @default(uuid())
  title          String
  type           String          // demo/poc/training/seminar
  description    String?         @db.Text
  customerId     String?         // 关联客户(可选)
  location       String?
  startTime      DateTime
  endTime        DateTime
  status         ActivityStatus  @default(draft)
  approvalStatus ApprovalStatus  @default(none)
  approvalNotes  String?         @db.Text
  approvedById   String?
  approvedAt     DateTime?
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  customer   Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy  User               @relation("ActivityCreator", fields: [createdById], references: [id])
  approvedBy User?              @relation("ActivityApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  qrCodes    ActivityQrCode[]
  signIns    ActivitySignIn[]
  questions  ActivityQuestion[]

  @@index([type])
  @@index([status])
  @@index([approvalStatus])
  @@index([startTime])
  @@map("presales_activities")
}

// 活动二维码
model ActivityQrCode {
  id         String   @id @default(uuid())
  activityId String
  codeType   String   // exclusive/generic
  qrCodeUrl  String   // 二维码图片URL
  qrCodeData String   @db.Text // 二维码数据
  validFrom  DateTime
  validUntil DateTime?
  isActive   Boolean  @default(true)
  scanCount  Int      @default(0)
  createdAt  DateTime @default(now())

  activity PresalesActivity   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  signIns  ActivitySignIn[]

  @@index([activityId])
  @@index([codeType])
  @@map("activity_qr_codes")
}

// 活动签到记录
model ActivitySignIn {
  id            String   @id @default(uuid())
  activityId    String
  qrCodeId      String
  customerId    String?  // 关联已有客户
  customerName  String
  phone         String
  email         String?
  company       String?
  title         String?  // 职位
  isNewCustomer Boolean  @default(true)
  notes         String?  @db.Text
  signedAt      DateTime @default(now())
  createdById   String?
  createdAt     DateTime @default(now())

  activity  PresalesActivity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  qrCode    ActivityQrCode    @relation(fields: [qrCodeId], references: [id])
  customer  Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  questions ActivityQuestion[]

  @@index([activityId])
  @@index([customerId])
  @@index([phone])
  @@map("activity_sign_ins")
}

// 活动问题
model ActivityQuestion {
  id          String   @id @default(uuid())
  activityId  String
  signInId    String
  customerId  String?  // 关联客户
  question    String   @db.Text
  category    String?  // product/pricing/technical/implementation/others
  priority    String?  // high/medium/low
  aiAnalysis  Json?    // AI分析结果
  status      String   @default("pending") // pending/answered/closed
  answer      String?  @db.Text
  answeredAt  DateTime?
  answeredBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activity PresalesActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  signIn   ActivitySignIn   @relation(fields: [signInId], references: [id], onDelete: Cascade)
  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([activityId])
  @@index([signInId])
  @@index([customerId])
  @@index([category])
  @@index([status])
  @@map("activity_questions")
}

// ==================== Proposal Enhanced Models ====================

// 方案模板库
model ProposalTemplate {
  id          String   @id @default(uuid())
  name        String
  category    String   // 行业分类
  description String?  @db.Text
  content     String   @db.Text  // JSON格式模板内容
  products    Json?    // 推荐产品配置
  terms       String?  @db.Text  // 标准条款
  tags        Json?    // string[] 标签
  usageCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("proposal_templates")
}

// 需求分析记录
model RequirementAnalysis {
  id           String   @id @default(uuid())
  proposalId   String   @unique
  customerId   String

  // 需求来源
  sourceType   String   // manual, ai_recording, ai_followup
  recordingId  String?  // 关联录音

  // 需求内容
  rawContent   String?  @db.Text  // 原始输入/AI提取
  aiEnhanced   Boolean  @default(false)
  finalContent String?  @db.Text  // 最终确认的需求

  // AI分析结果
  extractedNeeds    Json?  // AI提取的需求列表
  painPoints        Json?  // 痛点分析
  budgetHint        Json?  // 预算线索
  decisionTimeline  String?

  // 状态
  status       String   @default("draft")  // draft, confirmed

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("requirement_analyses")
}

// 内部评审记录
model ProposalReview {
  id           String   @id @default(uuid())
  proposalId   String   @unique

  // 评审状态
  status       String   @default("pending")  // pending, approved, rejected

  // 推送领导
  reviewerId   String?  // 评审人ID

  // 共享团队
  sharedWith   Json?    // 共享的团队成员ID[]

  // 评审意见
  comments     Json?    // [{userId, comment, createdAt}]

  // 结果
  result       String?  // approved, rejected
  resultNotes  String?  @db.Text
  reviewedAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([status])
  @@map("proposal_reviews")
}

// 客户提案记录
model CustomerProposalRecord {
  id             String   @id @default(uuid())
  proposalId     String   @unique

  // 邮件信息
  emailTo        String   // 收件人
  emailCc        Json?    // 抄送列表
  emailSubject   String?
  emailBody      String?  @db.Text

  // 发送状态
  sendStatus     String   @default("draft")  // draft, sent, delivered, opened, failed
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  openCount      Int      @default(0)

  // 链接跟踪
  trackingToken  String?  @unique
  viewUrl        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([sendStatus])
  @@map("customer_proposal_records")
}

// 商务谈判记录
model NegotiationRecord {
  id           String   @id @default(uuid())
  proposalId   String   @unique

  // 谈判记录
  discussions  Json?    // [{date, content, participants}]

  // 条款确认
  agreedTerms  Json?    // 确认的条款

  // 最终文档
  finalDocumentUrl String?

  // 状态
  status       String   @default("ongoing")  // ongoing, completed, cancelled

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([status])
  @@map("negotiation_records")
}

// ==================== Company Search Cache ====================

// 企业搜索缓存
model CompanySearchCache {
  id                  String   @id @default(uuid())
  companyName         String   @unique  // 企业名称（唯一索引）
  intelligenceResult  Json              // AI分析结果 (CompanyIntelligenceResult)
  searchResults       Json?             // 原始搜索结果
  source              String   @default("web_search") // 数据来源: web_search, llm, mock
  hitCount            Int      @default(0) // 缓存命中次数
  createdAt           DateTime @default(now())
  expiresAt           DateTime          // 过期时间
  updatedAt           DateTime @updatedAt

  @@index([companyName])
  @@index([expiresAt])
  @@index([source])
  @@map("company_search_cache")
}

// ==================== 企业知识库模型 ====================

// 知识库文档
model KnowledgeDocument {
  id            String   @id @default(cuid())
  title         String
  category      String   // product_pricing | proposal_template | contract_template | custom
  subCategory   String?
  description   String?  @db.Text
  fileUrl       String?
  fileName      String?
  fileType      String?  // xlsx, csv, pdf, docx, png, jpg
  fileSize      Int?
  content       String?  @db.LongText
  metadata      Json?
  tags          Json?
  isActive      Boolean  @default(true)
  version       Int      @default(1)
  createdById   String
  createdBy     User     @relation("KnowledgeDocCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("knowledge_documents")
}

// 产品价格表
model ProductPricing {
  id            String   @id @default(cuid())
  documentId    String?
  productName   String
  productCode   String?
  category      String?
  specification String?  @db.Text
  unitPrice     Decimal  @db.Decimal(12, 2)
  unit          String?
  minQuantity   Int?
  discount      Json?
  validFrom     DateTime?
  validUntil    DateTime?
  isActive      Boolean  @default(true)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productName])
  @@index([category])
  @@index([isActive])
  @@map("product_pricings")
}

// 合同模板
model ContractTemplate {
  id            String   @id @default(cuid())
  name          String
  category      String
  description   String?  @db.Text
  content       String   @db.LongText
  variables     Json?
  tags          Json?
  usageCount    Int      @default(0)
  isActive      Boolean  @default(true)
  createdById   String
  createdBy     User     @relation("ContractTemplateCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("contract_templates")
}

// 自定义数据表
model CustomDataTable {
  id            String   @id @default(cuid())
  name          String
  description   String?
  columns       Json
  rows          CustomDataRow[]
  createdById   String
  createdBy     User     @relation("CustomTableCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@map("custom_data_tables")
}

// 自定义数据行
model CustomDataRow {
  id            String   @id @default(cuid())
  tableId       String
  table         CustomDataTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tableId])
  @@map("custom_data_rows")
}